{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@bluemillstudio/gantt": ["src/index.ts"],
      "@bluemillstudio/gantt/store": ["src/store/index.ts"],
      "@bluemillstudio/gantt/query": ["src/query.ts"],
      "@bluemillstudio/gantt/analysis": ["src/analysis.ts"]
    }
  },
  "include": ["docs/features/**/examples/*.tsx", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "reference", "example", "dist"]
}
